# ==========================================
# Notion2API Go — Configuration Template
# Copy to .env and fill in actual values
# ==========================================

# Core Credentials: Notion Account (JSON Object or Array)
# Required fields: token_v2, space_id, user_id
# Optional: space_view_id, user_name, user_email, cf_clearance
#
# Single account:
NOTION_ACCOUNTS='{"token_v2":"v03:your_token_here","space_id":"xxxx-xxxx","user_id":"xxxx-xxxx","space_view_id":"xxxx-xxxx","user_name":"Your Name","user_email":"you@email.com"}'

# Multiple accounts (JSON array, load-balanced):
# NOTION_ACCOUNTS='[{"token_v2":"...","space_id":"...","user_id":"..."},{"token_v2":"...","space_id":"...","user_id":"..."}]'

# API_KEY: Bearer Token for /v1/chat/completions auth (empty = auto-generated)
# API_KEY=sk-your-custom-key-here

# PORT: Service listening port (default: 8000)
PORT=8000

# HOST: Bind address (default: 0.0.0.0)
HOST=0.0.0.0

# APP_MODE: Controls feature set (lite|standard|heavy)
# - lite: minimal, no conversation tracking, no DB
# - standard: basic features
# - heavy: full features with SQLite conversation persistence
# APP_MODE=heavy

# DB_PATH: Path to SQLite database file (default: ./data/conversations.db)
# Only used in heavy mode
# DB_PATH=./data/conversations.db

# Debug mode: set to 1 to log raw Notion responses
# NOTION2API_DEBUG=1
